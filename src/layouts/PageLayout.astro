---
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<Layout title={title}>
  <header class="w-full h-[60px] border-b border-hairline flex items-center px-6 shrink-0 bg-canvas nav-frosted z-40 relative">
    <a href="/" class="text-[21px] font-semibold tracking-[0.231px] flex items-center gap-[8px] text-ink hover:opacity-80 transition-opacity">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"/><path d="m14.5 12.5 2-2"/><path d="m11.5 9.5 2-2"/><path d="m8.5 6.5 2-2"/><path d="m17.5 15.5 2-2"/></svg>
      <span>Online Ruler</span>
    </a>
  </header>

  <main class="flex-1 min-h-0 w-full overflow-y-auto p-6 md:p-12 relative z-0">
    <article class="max-w-[800px] mx-auto text-ink flex flex-col gap-4 text-[15px] leading-relaxed">
      <slot />
    </article>
    
    <footer class="mt-24 border-t border-hairline pt-8 max-w-[800px] mx-auto text-center text-body-muted text-[14px] pb-12">
      <div class="flex flex-wrap items-center justify-center gap-4 md:gap-6 mb-4">
        <a href="/" class="hover:text-ink transition-colors">Home</a>
        <a href="/about" class="hover:text-ink transition-colors">About Us</a>
        <a href="/contact" class="hover:text-ink transition-colors">Contact Us</a>
        <a href="/privacy" class="hover:text-ink transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-ink transition-colors">Terms & Conditions</a>
      </div>
      <p>&copy; {new Date().getFullYear()} Online Ruler. All rights reserved.</p>
    </footer>
  </main>
</Layout>
