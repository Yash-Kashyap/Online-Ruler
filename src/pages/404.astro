---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Page Not Found - Online Ruler">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center">
    <h1 class="text-[64px] md:text-[80px] font-semibold tracking-tight-apple-display text-primary mb-2 leading-none">404</h1>
    <h2 class="text-[24px] md:text-[32px] font-medium tracking-tight-apple mb-4">Page Not Found</h2>
    <p class="text-body-muted text-[17px] max-w-[400px] mx-auto mb-8">
      Oops! It looks like the page you are looking for has been moved or doesn't exist.
    </p>
    <div>
      <a href="/" class="btn-primary text-[15px] hover:opacity-90 transition-opacity">
        Return to Homepage
      </a>
    </div>
  </div>
</PageLayout>
