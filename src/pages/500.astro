---
import PageLayout from '../layouts/PageLayout.astro';

interface Props {
  error?: unknown;
}
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<PageLayout title="Server Error - Online Ruler">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center">
    <h1 class="text-[64px] md:text-[80px] font-semibold tracking-tight-apple-display text-primary mb-2 leading-none">500</h1>
    <h2 class="text-[24px] md:text-[32px] font-medium tracking-tight-apple mb-4">Internal Server Error</h2>
    <p class="text-body-muted text-[17px] max-w-[400px] mx-auto mb-8">
      Something went wrong on our end. Please try refreshing the page or return later.
    </p>
    <div>
      <a href={`${basePath}/`} class="btn-primary text-[15px] hover:opacity-90 transition-opacity">
        Return to Homepage
      </a>
    </div>
  </div>
</PageLayout>
